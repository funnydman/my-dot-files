{
  "layer": "top",
  "position": "top",
  "height": 22,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "tray",
    "hyprland/language",
    "custom/brightness-internal",
    "custom/brightness-external",
    "bluetooth",
    "pulseaudio",
    "network",
    "memory",
    "cpu",
    "battery"
  ],
  "hyprland/workspaces": {
    "on-click": "activate",
    "disable-scroll": true,
    "tooltip": false
  },
  "hyprland/window": {
    "format": "{title}",
    "max-length": 50
  },
  "hyprland/language": {
    "format": "σΑ¨™ {short}"
  },
  "cpu": {
    "interval": 2,
    "format": "σΑç¦ {usage}%"
  },
  "memory": {
    "interval": 2,
    "format": "σΑ‰ö {percentage}%"
  },
  "clock": {
    "format": " {:%H:%M %a}",
    "format-alt": " {:%d/%m/%Y %H:%M:%S}",
    "tooltip-format": "<span>{calendar}</span>"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "σΑ¦ä",
      "deactivated": "σΑΨΪ"
    }
  },
  "network": {
    "interval": 2,
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "format-wifi": "{icon} {essid} σΑ΅ö{bandwidthDownBits} σΑï£{bandwidthUpBits}",
    "format-ethernet": "σΑàÄ {ifname}",
    "format-disconnected": "σΑ•Σ Disconnected",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}\nσΑ΅ö {bandwidthDownBits} σΑï£ {bandwidthUpBits}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}\nσΑ΅ö {bandwidthDownBits} σΑï£ {bandwidthUpBits}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "kitty --title nmtui --class nmtui nmtui"
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σΑ²Ö",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "format-full": "σΑ²Ö 100%",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "",
    "format-disabled": "σΑ²≤",
    "format-off": "σΑ²≤",
    "format-connected": "",
    "tooltip-format": "{num_connections} connected",
    "on-click": "blueman-manager"
  },
  "custom/brightness-internal": {
    "format": "{icon} {percentage}%",
    "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
    "return-type": "json",
    "exec": "brightnessctl -d intel_backlight get | { read x; max=$(brightnessctl -d intel_backlight max); pct=$((x * 100 / max)); echo '{\"percentage\":'$pct'}'; }",
    "exec-if": "hyprctl monitors -j | jq -e '.[] | select(.name == \"eDP-1\" and .disabled == false)' > /dev/null",
    "on-scroll-up": "brightnessctl -d intel_backlight set 5%+",
    "on-scroll-down": "brightnessctl -d intel_backlight set 5%-",
    "interval": 2,
    "tooltip": false
  },
  "custom/brightness-external": {
    "format": "{icon} {percentage}%",
    "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
    "return-type": "json",
    "exec": "BUS=$(~/.config/scripts/ddc-bus.sh) && ddcutil --noverify --sleep-multiplier 0.1 --bus $BUS getvcp 10 2>/dev/null | grep -oP 'current.*?=\\s*\\K[0-9]+' | { read x; echo '{\"percentage\":'${x}'}'; }",
    "exec-if": "hyprctl monitors -j | jq -e '.[] | select(.name != \"eDP-1\" and .disabled == false)' > /dev/null",
    "on-scroll-up": "BUS=$(~/.config/scripts/ddc-bus.sh) && ddcutil --noverify --sleep-multiplier 0.1 --bus $BUS setvcp 10 + 5 && pkill -RTMIN+8 waybar",
    "on-scroll-down": "BUS=$(~/.config/scripts/ddc-bus.sh) && ddcutil --noverify --sleep-multiplier 0.1 --bus $BUS setvcp 10 - 5 && pkill -RTMIN+8 waybar",
    "signal": 8,
    "interval": 2,
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü mute",
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "tooltip-format": "{volume}%",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "scroll-step": 5
  },
  "tray": {
    "icon-size": 14,
    "spacing": 8
  }
}
